# ─── Sanity CMS ────────────────────────────────────────────────────────────────
# Prefixo NEXT_PUBLIC_ é obrigatório no Next.js para variáveis acessíveis no browser.
# Estas variáveis são PÚBLICAS (não contêm segredos). Usadas para leitura dos artigos
# publicados pelo CDN público do Sanity e para o Sanity Studio embutido em /admin/.

NEXT_PUBLIC_SANITY_PROJECT_ID=seu-project-id-aqui
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-01-01

# ─── Resend (formulário de contato) ────────────────────────────────────────────
# Variável de servidor — NUNCA prefixar com NEXT_PUBLIC_.
# Crie uma chave em resend.com/api-keys com permissão de envio.

RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Webhook de revalidação ────────────────────────────────────────────────────
# Gere um segredo aleatório (ex.: openssl rand -hex 32) e configure-o no webhook
# do Sanity em manage.sanity.io → projeto → API → Webhooks.

SANITY_WEBHOOK_SECRET=seu-segredo-aleatorio-aqui
